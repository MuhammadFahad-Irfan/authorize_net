# Authorize.net sandbox credentials
# Get these from https://sandbox.authorize.net (Account -> API Credentials & Keys)
AUTHORIZE_API_LOGIN_ID=your_sandbox_login_id
AUTHORIZE_TRANSACTION_KEY=your_sandbox_transaction_key

# Server config
PORT=4000

# Frontend origin (used for CORS + Accept Hosted return/iframe communication)
FRONTEND_URL=http://localhost:5173

# Public backend URL (Authorize.net will POST the redirect/iframe-communicator messages here)
BACKEND_URL=http://localhost:4000
